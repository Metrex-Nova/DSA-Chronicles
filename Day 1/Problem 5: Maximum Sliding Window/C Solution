Given an array of integers arr of size N and an integer K. Find the maximum element in each
window of size K from the left to right. More formally,
ans[i] = max(arr[i], arr[i+1], … , arr[i+K-1]) where 0 ≤ i ≤ N-K
Return the array ans consisting of the maximum elements in each window.

Sample Test Case 1:
Input:
6 2
4 2 5 6 1 3
Output:
4 5 6 6 3
Sample Test Case 2:
Input:
8 3
1 3 -1 -3 5 3 6 7
Output:
3 3 5 5 6 7


Solution:-

#include<stdio.h>
#include<stdlib.h>
#include<string.h>
#define MAX 1000
int main(){
    printf("Hello World!\n");
    int n;
    int k;
    printf("Please enter the size of array: ");
    scanf("%d", &n);
    printf("Please enter the size of window: ");
    scanf("%d", &k);
    int arr[MAX];
    int dq[MAX];
    int ans[MAX];
    for(int i = 0; i<n; i++){
        printf("Please enter element %d of the array: ", i+1);
        scanf("%d", &arr[i]);
    }
    int front = 0; 
    int rear = -1;
    int idx = 0;
    for(int i = 0; i<n; i++){
        while(front<=rear && dq[front] <= i-k){
            front++;
        }
        while(front<=rear && arr[dq[rear]] <= arr[i]){
            rear--;
        }
        dq[++rear] = i;
        if(i>=k-1){
            ans[idx++] = arr[dq[front]];
        }
    }
    for(int i = 0; i<idx; i++){
        printf("%d ", ans[i]);
    }
    return 0;
}

